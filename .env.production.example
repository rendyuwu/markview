# Domain
DOMAIN="markview.yourdomain.com"

# PostgreSQL
POSTGRES_USER=markview
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL="postgresql://markview:CHANGE_ME_STRONG_PASSWORD@db:5432/markview"

# Session — generate with: openssl rand -hex 32
SESSION_SECRET=""

# Registration
ENABLE_REGISTER="false"

# App
NEXT_PUBLIC_APP_NAME="MarkView"
NODE_ENV="production"
